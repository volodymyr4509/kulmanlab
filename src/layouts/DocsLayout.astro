---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  entrySlug?: string;
}

const { title, description = '', keywords = [], entrySlug = '' } = Astro.props;
const canonical = `https://kulmanlab.com/docs${entrySlug ? '/' + entrySlug : ''}`;
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const sidebar = [
  {
    title: 'Overview',
    items: [{ label: 'Command Reference', href: '/docs' }],
  },
  {
    title: 'Shapes',
    items: [
      { label: 'Line', href: '/docs/commands/line' },
      { label: 'Polyline', href: '/docs/commands/polyline' },
      { label: 'Rectangle', href: '/docs/commands/rectangle' },
      { label: 'Circle', href: '/docs/commands/circle' },
      { label: 'Arc', href: '/docs/commands/arc' },
      { label: 'Ellipse', href: '/docs/commands/ellipse' },
      { label: 'Text', href: '/docs/commands/text' },
      { label: 'Spline CV', href: '/docs/commands/spline-cv' },
      { label: 'Spline Fit', href: '/docs/commands/spline-fit' },
    ],
  },
  {
    title: 'Edit',
    items: [
      { label: 'Move', href: '/docs/commands/move' },
      { label: 'Copy', href: '/docs/commands/copy' },
      { label: 'Rotate', href: '/docs/commands/rotate' },
      { label: 'Mirror', href: '/docs/commands/mirror' },
      { label: 'Scale', href: '/docs/commands/scale' },
      { label: 'Delete', href: '/docs/commands/delete' },
      { label: 'Trim', href: '/docs/commands/trim' },
      { label: 'Extend', href: '/docs/commands/extend' },
      { label: 'Offset', href: '/docs/commands/offset' },
      { label: 'Fillet', href: '/docs/commands/fillet' },
      { label: 'Chamfer', href: '/docs/commands/chamfer' },
      { label: 'Undo', href: '/docs/commands/undo' },
      { label: 'Redo', href: '/docs/commands/redo' },
    ],
  },
  {
    title: 'Markup',
    items: [
      { label: 'Leader', href: '/docs/commands/leader' },
      { label: 'Leader+', href: '/docs/commands/leader-add' },
      { label: 'Leader−', href: '/docs/commands/leader-remove' },
      { label: 'Dim Linear', href: '/docs/commands/dim-linear' },
      { label: 'Dim Aligned', href: '/docs/commands/dim-aligned' },
      { label: 'Dim Continue', href: '/docs/commands/dim-continue' },
      { label: 'Dim Radius', href: '/docs/commands/dim-radius' },
      { label: 'Dim Diameter', href: '/docs/commands/dim-diameter' },
      { label: 'Dim Angular', href: '/docs/commands/dim-angular' },
    ],
  },
  {
    title: 'Layer',
    items: [
      { label: 'LayerMakeCurrent', href: '/docs/commands/layer-make-current' },
      { label: 'LayerMatch', href: '/docs/commands/layer-match' },
      { label: 'LayerIsolate', href: '/docs/commands/layer-isolate' },
      { label: 'LayerUnfreezeAll', href: '/docs/commands/layer-unfreeze-all' },
    ],
  },
  {
    title: 'Layouts',
    items: [
      { label: 'ViewportRectangle', href: '/docs/commands/viewport-rectangle' },
      { label: 'ViewportCopy', href: '/docs/commands/viewport-copy' },
      { label: 'PageManager', href: '/docs/commands/page-manager' },
    ],
  },
  {
    title: 'Navigate',
    items: [
      { label: 'Pan', href: '/docs/commands/pan' },
      { label: 'Zoom In', href: '/docs/commands/zoom-in' },
      { label: 'Zoom Out', href: '/docs/commands/zoom-out' },
      { label: 'Fit', href: '/docs/commands/fit' },
    ],
  },
  {
    title: 'Measure',
    items: [
      { label: 'Distance', href: '/docs/commands/distance' },
      { label: 'Angle', href: '/docs/commands/angle' },
    ],
  },
  {
    title: 'Style',
    items: [
      { label: 'Match Properties', href: '/docs/commands/match-properties' },
    ],
  },
  {
    title: 'File',
    items: [
      { label: 'Import', href: '/docs/commands/import' },
      { label: 'New File', href: '/docs/commands/new-file' },
      { label: 'Files', href: '/docs/commands/files' },
      { label: 'Print', href: '/docs/commands/print' },
      { label: 'Export', href: '/docs/commands/export' },
      { label: 'WipeStorage', href: '/docs/commands/wipestorage' },
    ],
  },
  {
    title: 'Interface',
    items: [
      { label: 'Grid & Snap', href: '/docs/interface/grid-snap' },
      { label: 'Linetype', href: '/docs/interface/linetype' },
      { label: 'Lineweight', href: '/docs/interface/lineweight' },
      { label: 'Text Editor', href: '/docs/interface/text-editor' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://kulmanlab.com/og.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body class="bg-slate-900 text-slate-50 antialiased font-sans">

    <SiteHeader active="docs" />

    <div class="mx-auto flex max-w-6xl">

      <!-- Sidebar -->
      <aside class="hidden lg:block sticky top-[57px] h-[calc(100vh-57px)] w-64 flex-shrink-0 overflow-y-auto border-r border-slate-800 px-3 py-8">

        <!-- Overview (always visible, not collapsible) -->
        <div class="mb-2">
          {sidebar[0].items.map(item => {
            const active = currentPath === item.href;
            return (
              <a
                href={item.href}
                class={`flex items-center gap-2 rounded px-3 py-1.5 text-sm font-medium transition-colors ${
                  active ? 'bg-brand/10 text-brand' : 'text-slate-300 hover:text-slate-50'
                }`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                {item.label}
              </a>
            );
          })}
        </div>

        <div class="my-3 border-t border-slate-800" />

        <!-- Collapsible sections -->
        {sidebar.slice(1).map(group => {
          const isOpen = group.items.some(item => currentPath === item.href);
          return (
            <details open={isOpen} class="group mb-1">
              <summary class="flex cursor-pointer list-none items-center gap-2 rounded px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors select-none">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-3 w-3 flex-shrink-0 transition-transform group-open:rotate-90"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                {group.title}
              </summary>
              <ul class="ml-3 mt-0.5 border-l border-slate-800 pl-3">
                {group.items.map(item => {
                  const active = currentPath === item.href;
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={`block rounded-r py-1 pl-2 pr-3 text-sm transition-colors ${
                          active
                            ? 'border-l-2 -ml-[1px] border-brand text-brand font-medium bg-brand/5'
                            : 'text-slate-400 hover:text-slate-200'
                        }`}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </details>
          );
        })}
      </aside>

      <!-- Content -->
      <main class="min-w-0 flex-1 px-6 py-12 lg:px-16">
        <article class="prose max-w-3xl">
          <slot />
        </article>
      </main>

    </div>

    <SiteFooter />

  </body>
</html>
