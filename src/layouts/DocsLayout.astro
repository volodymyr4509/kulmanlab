const base = lang === 'en' ? '/docs' : `/${lang}/docs`;
const canonical = `https://kulmanlab.com${base}${entrySlug ? '/' + entrySlug : ''}`;
const currentPath = Astro.url.pathname.replace(/\/$/, '');

