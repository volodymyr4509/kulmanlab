---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  entrySlug?: string;
}

const { title, description = '', keywords = [], entrySlug = '' } = Astro.props;
const canonical = `https://kulmanlab.com/docs${entrySlug ? '/' + entrySlug : ''}`;
const APP_URL = 'https://app.kulmanlab.com';
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const sidebar = [
  {
    title: 'Overview',
    items: [{ label: 'Command Reference', href: '/docs' }],
  },
  {
    title: 'Shapes',
    items: [
      { label: 'Line', href: '/docs/commands/line' },
      { label: 'Polyline', href: '/docs/commands/polyline' },
      { label: 'Rectangle', href: '/docs/commands/rectangle' },
      { label: 'Circle', href: '/docs/commands/circle' },
      { label: 'Arc', href: '/docs/commands/arc' },
      { label: 'Ellipse', href: '/docs/commands/ellipse' },
      { label: 'Text', href: '/docs/commands/text' },
      { label: 'Spline CV', href: '/docs/commands/spline-cv' },
      { label: 'Spline Fit', href: '/docs/commands/spline-fit' },
    ],
  },
  {
    title: 'Edit',
    items: [
      { label: 'Move', href: '/docs/commands/move' },
      { label: 'Copy', href: '/docs/commands/copy' },
      { label: 'Rotate', href: '/docs/commands/rotate' },
      { label: 'Mirror', href: '/docs/commands/mirror' },
      { label: 'Scale', href: '/docs/commands/scale' },
      { label: 'Delete', href: '/docs/commands/delete' },
      { label: 'Trim', href: '/docs/commands/trim' },
      { label: 'Extend', href: '/docs/commands/extend' },
      { label: 'Offset', href: '/docs/commands/offset' },
      { label: 'Fillet', href: '/docs/commands/fillet' },
      { label: 'Chamfer', href: '/docs/commands/chamfer' },
      { label: 'Undo', href: '/docs/commands/undo' },
      { label: 'Redo', href: '/docs/commands/redo' },
    ],
  },
  {
    title: 'Markup',
    items: [
      { label: 'Leader', href: '/docs/commands/leader' },
      { label: 'Leader+', href: '/docs/commands/leader-add' },
      { label: 'Leader−', href: '/docs/commands/leader-remove' },
      { label: 'Dim Linear', href: '/docs/commands/dim-linear' },
      { label: 'Dim Aligned', href: '/docs/commands/dim-aligned' },
      { label: 'Dim Continue', href: '/docs/commands/dim-continue' },
      { label: 'Dim Radius', href: '/docs/commands/dim-radius' },
      { label: 'Dim Diameter', href: '/docs/commands/dim-diameter' },
      { label: 'Dim Angular', href: '/docs/commands/dim-angular' },
    ],
  },
  {
    title: 'Layer',
    items: [
      { label: 'LayerMakeCurrent', href: '/docs/commands/layer-make-current' },
      { label: 'LayerMatch', href: '/docs/commands/layer-match' },
      { label: 'LayerIsolate', href: '/docs/commands/layer-isolate' },
      { label: 'LayerUnfreezeAll', href: '/docs/commands/layer-unfreeze-all' },
    ],
  },
  {
    title: 'Layouts',
    items: [
      { label: 'ViewportRectangle', href: '/docs/commands/viewport-rectangle' },
      { label: 'ViewportCopy', href: '/docs/commands/viewport-copy' },
      { label: 'PageManager', href: '/docs/commands/page-manager' },
    ],
  },
  {
    title: 'Navigate',
    items: [
      { label: 'Pan', href: '/docs/commands/pan' },
      { label: 'Zoom In', href: '/docs/commands/zoom-in' },
      { label: 'Zoom Out', href: '/docs/commands/zoom-out' },
      { label: 'Fit', href: '/docs/commands/fit' },
    ],
  },
  {
    title: 'Measure',
    items: [
      { label: 'Distance', href: '/docs/commands/distance' },
      { label: 'Angle', href: '/docs/commands/angle' },
    ],
  },
  {
    title: 'Style',
    items: [
      { label: 'Match Properties', href: '/docs/commands/match-properties' },
    ],
  },
  {
    title: 'File',
    items: [
      { label: 'Import', href: '/docs/commands/import' },
      { label: 'New File', href: '/docs/commands/new-file' },
      { label: 'Files', href: '/docs/commands/files' },
      { label: 'Print', href: '/docs/commands/print' },
      { label: 'Export', href: '/docs/commands/export' },
      { label: 'WipeStorage', href: '/docs/commands/wipestorage' },
    ],
  },
  {
    title: 'Interface',
    items: [
      { label: 'Grid & Snap', href: '/docs/interface/grid-snap' },
      { label: 'Linetype', href: '/docs/interface/linetype' },
      { label: 'Lineweight', href: '/docs/interface/lineweight' },
      { label: 'Text Editor', href: '/docs/interface/text-editor' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://kulmanlab.com/og.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body class="bg-slate-900 text-slate-50 antialiased font-sans">

    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900/90 backdrop-blur">
      <nav class="mx-auto flex max-w-screen-xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3 text-slate-50 hover:text-brand transition-colors">
          <img src="/logo.svg" alt="KulmanLab logo" class="h-8 w-8 rounded-lg" />
          <span class="font-semibold tracking-wide">KulmanLab</span>
        </a>
        <div class="flex items-center gap-6">
          <a href="/docs" class="text-sm text-brand font-medium">Docs</a>
          <a
            href={APP_URL}
            class="rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white hover:bg-brand-light transition-colors"
          >
            Launch App
          </a>
        </div>
      </nav>
    </header>

    <div class="mx-auto flex max-w-screen-xl">

      <!-- Sidebar -->
      <aside class="hidden lg:block sticky top-[57px] h-[calc(100vh-57px)] w-60 flex-shrink-0 overflow-y-auto border-r border-slate-800 px-4 py-8">
        {sidebar.map(group => (
          <div class="mb-6">
            <div class="mb-1.5 px-3 text-xs font-semibold uppercase tracking-widest text-slate-500">
              {group.title}
            </div>
            <ul>
              {group.items.map(item => {
                const active = currentPath === item.href;
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`block rounded px-3 py-1 text-sm transition-colors ${
                        active
                          ? 'bg-brand/10 text-brand font-medium'
                          : 'text-slate-400 hover:text-slate-200'
                      }`}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </aside>

      <!-- Content -->
      <main class="min-w-0 flex-1 px-6 py-12 lg:px-16">
        <article class="prose max-w-3xl">
          <slot />
        </article>
      </main>

    </div>

    <!-- Footer -->
    <footer class="border-t border-slate-800 py-10">
      <div class="mx-auto max-w-screen-xl px-6 flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
        <a href="/" class="flex items-center gap-2 text-slate-400 hover:text-slate-200 transition-colors">
          <img src="/logo.svg" alt="KulmanLab" class="h-6 w-6 rounded" />
          <span class="text-sm font-medium">KulmanLab</span>
        </a>
        <nav class="flex gap-6 text-sm text-slate-500">
          <a href={APP_URL} class="hover:text-slate-300 transition-colors">App</a>
          <a href="/docs" class="hover:text-slate-300 transition-colors">Docs</a>
        </nav>
        <p class="text-sm text-slate-600">© {new Date().getFullYear()} KulmanLab</p>
      </div>
    </footer>

  </body>
</html>
