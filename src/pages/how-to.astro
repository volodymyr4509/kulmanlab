---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import HowToBody from '../components/HowToBody.astro';
import type { Lang } from '../i18n/translations';
import { buildAlternates } from '../i18n/utils';
import { howtoContent } from '../i18n/howto-content';

const lang: Lang = 'en';
const c = howtoContent[lang];
---

<Layout
  title={c.title}
  description={c.desc}
  canonical="https://kulmanlab.com/how-to/"
  lang={lang}
  alternates={buildAlternates('how-to')}
>

  <SiteHeader active="howto" lang={lang} />

  <HowToBody lang={lang} />

  <SiteFooter lang={lang} />

</Layout>
