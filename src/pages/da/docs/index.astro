---
import { getEntry, render } from 'astro:content';
import DocsLayout from '../../../layouts/DocsLayout.astro';
const entry = await getEntry('docs-da', 'index');
const { Content } = await render(entry);
---
<DocsLayout title={entry.data.title} description={entry.data.description} keywords={entry.data.keywords} entrySlug="" lang="da">
  <Content />
</DocsLayout>
