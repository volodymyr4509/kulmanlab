---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PrivacyBody from '../components/PrivacyBody.astro';
import type { Lang } from '../i18n/translations';
import { buildAlternates } from '../i18n/utils';
import { privacyContent } from '../i18n/privacy-content';

const lang: Lang = 'en';
const c = privacyContent[lang];
---

<Layout
  title={c.title}
  description={c.desc}
  canonical="https://kulmanlab.com/privacy/"
  lang={lang}
  alternates={buildAlternates('privacy')}
>

  <SiteHeader lang={lang} />

  <PrivacyBody lang={lang} />

  <SiteFooter lang={lang} />

</Layout>
