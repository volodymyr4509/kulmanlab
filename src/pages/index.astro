---
import Layout from '../layouts/Layout.astro';

const APP_URL = 'https://app.kulmanlab.com';
const DOCS_URL = '/docs';

const features = [
  {
    title: 'Full Drawing Toolkit',
    body: 'Lines, arcs, circles, polylines, splines, ellipses, text, and multileaders. Everything you need for 2D geometry.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />`,
  },
  {
    title: 'Edit & Modify Commands',
    body: 'Move, copy, rotate, mirror, scale, offset, trim, extend, fillet, chamfer. Full modify suite via toolbar or command terminal.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 3M21 7.5H7.5" />`,
  },
  {
    title: 'Dimensions & Annotation',
    body: 'Linear, aligned, radius, diameter, angular, and continue dimensions. All stored as standard DXF DIMENSION objects.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />`,
  },
  {
    title: 'Layer Management',
    body: 'Freeze, lock, isolate, and configure color, linetype, and lineweight per layer. Full control over layer visibility and printability.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3" />`,
  },
  {
    title: 'DXF Import & Export',
    body: 'Read and write AutoCAD 2018 (AC1032) DXF. Compatible with AutoCAD, LibreCAD, FreeCAD, QCAD, and any DXF-capable software.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l3 3m0 0l3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
  },
  {
    title: 'Grip Editing',
    body: 'Select any entity and drag its grip handles to reshape geometry directly on the canvas. Type a value while dragging for exact displacement.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zm-7.518-.267A8.25 8.25 0 1120.25 10.5M8.288 14.212A5.25 5.25 0 1117.25 10.5" />`,
  },
];

const badges = [
  'No installation',
  'No account required',
  'Files stay on your machine',
  'Free forever',
];
---

<Layout
  title="KulmanLab — Free Browser-Based 2D CAD Editor"
  description="Professional 2D CAD in your browser. Open DXF files, draw, dimension, and export. No installation. No subscription. Your files never leave your machine."
>

  <!-- ── Navigation ─────────────────────────────────────── -->
  <header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900/90 backdrop-blur">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-3 text-slate-50 hover:text-brand transition-colors">
        <img src="/logo.svg" alt="KulmanLab logo" class="h-8 w-8 rounded-lg" />
        <span class="font-semibold tracking-wide">KulmanLab</span>
      </a>
      <div class="flex items-center gap-6">
        <a href={DOCS_URL} class="text-sm text-slate-400 hover:text-slate-200 transition-colors">Docs</a>
        <a
          href={APP_URL}
          class="rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white hover:bg-brand-light transition-colors"
        >
          Launch App
        </a>
      </div>
    </nav>
  </header>

  <main>

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="relative overflow-hidden border-b border-slate-800 py-24 md:py-32">
      <!-- Background grid -->
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(#4A8580 1px, transparent 1px), linear-gradient(90deg, #4A8580 1px, transparent 1px); background-size: 40px 40px;">
      </div>

      <div class="relative mx-auto max-w-6xl px-6">
        <div class="grid items-center gap-16 lg:grid-cols-2">

          <div>
            <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand/30 bg-brand/10 px-4 py-1.5 text-sm text-brand">
              <span class="h-2 w-2 rounded-full bg-brand animate-pulse"></span>
              Free · No sign-up required
            </div>

            <h1 class="mb-6 text-4xl font-bold leading-tight tracking-tight text-slate-50 md:text-5xl lg:text-6xl">
              Professional 2D&nbsp;CAD<br />
              <span class="text-brand">in your browser</span>
            </h1>

            <p class="mb-8 text-lg text-slate-400 leading-relaxed max-w-lg">
              Open DXF files, draw geometry, add dimensions, and export — without installing a single thing.
              Works in any modern desktop browser.
            </p>

            <div class="flex flex-wrap gap-4">
              <a
                href={APP_URL}
                class="inline-flex items-center gap-2 rounded-lg bg-brand px-6 py-3 font-medium text-white hover:bg-brand-light transition-colors"
              >
                Launch App
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <a
                href={DOCS_URL}
                class="inline-flex items-center gap-2 rounded-lg border border-slate-700 px-6 py-3 font-medium text-slate-300 hover:border-slate-500 hover:text-slate-50 transition-colors"
              >
                Documentation
              </a>
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
              {badges.map(b => (
                <span class="flex items-center gap-1.5 text-sm text-slate-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  {b}
                </span>
              ))}
            </div>
          </div>

          <!-- Decorative CAD canvas illustration -->
          <div class="hidden lg:block">
            <div class="relative rounded-xl border border-slate-700 bg-slate-800/50 p-2 shadow-2xl">
              <div class="rounded-lg border border-slate-700 bg-slate-900 overflow-hidden">
                <!-- Fake toolbar -->
                <div class="flex items-center gap-1 border-b border-slate-800 bg-slate-800/60 px-3 py-2">
                  <span class="h-3 w-3 rounded-full bg-slate-600"></span>
                  <span class="h-3 w-3 rounded-full bg-slate-600"></span>
                  <span class="h-3 w-3 rounded-full bg-slate-600"></span>
                  <span class="ml-4 h-4 w-20 rounded bg-slate-700"></span>
                  <span class="h-4 w-16 rounded bg-slate-700"></span>
                  <span class="h-4 w-24 rounded bg-slate-700"></span>
                </div>
                <!-- Fake canvas with SVG drawing -->
                <svg
                  viewBox="0 0 480 320"
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-full"
                  style="background: #0f172a;"
                >
                  <!-- Grid dots -->
                  {Array.from({length: 12}).map((_, row) =>
                    Array.from({length: 18}).map((_, col) => (
                      <circle cx={col * 28 + 14} cy={row * 28 + 14} r="0.8" fill="#334155" />
                    ))
                  )}

                  <!-- Main rectangle (part outline) -->
                  <rect x="80" y="70" width="200" height="140" fill="none" stroke="#4A8580" stroke-width="1.5" />

                  <!-- Circle cutout -->
                  <circle cx="180" cy="140" r="40" fill="none" stroke="#4A8580" stroke-width="1.5" />

                  <!-- Construction lines -->
                  <line x1="180" y1="100" x2="180" y2="180" stroke="#334155" stroke-width="0.8" stroke-dasharray="4,3" />
                  <line x1="140" y1="140" x2="220" y2="140" stroke="#334155" stroke-width="0.8" stroke-dasharray="4,3" />

                  <!-- Dimension: horizontal width -->
                  <line x1="80" y1="235" x2="280" y2="235" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="80" y1="210" x2="80" y2="240" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="280" y1="210" x2="280" y2="240" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="80" y1="235" x2="92" y2="231" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="80" y1="235" x2="92" y2="239" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="280" y1="235" x2="268" y2="231" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="280" y1="235" x2="268" y2="239" stroke="#94a3b8" stroke-width="0.8" />
                  <text x="180" y="249" text-anchor="middle" fill="#94a3b8" font-size="9" font-family="monospace">200.00</text>

                  <!-- Dimension: vertical height -->
                  <line x1="305" y1="70" x2="305" y2="210" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="280" y1="70" x2="310" y2="70" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="280" y1="210" x2="310" y2="210" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="305" y1="70" x2="301" y2="82" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="305" y1="70" x2="309" y2="82" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="305" y1="210" x2="301" y2="198" stroke="#94a3b8" stroke-width="0.8" />
                  <line x1="305" y1="210" x2="309" y2="198" stroke="#94a3b8" stroke-width="0.8" />
                  <text x="320" y="144" text-anchor="start" fill="#94a3b8" font-size="9" font-family="monospace">140.00</text>

                  <!-- Radius dimension -->
                  <line x1="180" y1="140" x2="207" y2="112" stroke="#94a3b8" stroke-width="0.8" />
                  <text x="212" y="108" text-anchor="start" fill="#94a3b8" font-size="9" font-family="monospace">R40.00</text>

                  <!-- Selected entity grip points -->
                  <rect x="77" y="67" width="6" height="6" fill="#4A8580" />
                  <rect x="277" y="67" width="6" height="6" fill="#4A8580" />
                  <rect x="77" y="207" width="6" height="6" fill="#4A8580" />
                  <rect x="277" y="207" width="6" height="6" fill="#4A8580" />
                  <rect x="177" y="67" width="6" height="6" fill="#4A8580" />

                  <!-- Snap indicator -->
                  <circle cx="80" cy="70" r="6" fill="none" stroke="#5fa39d" stroke-width="1" />

                  <!-- Command terminal -->
                  <rect x="0" y="292" width="480" height="28" fill="#1e293b" />
                  <text x="10" y="309" fill="#4A8580" font-size="9" font-family="monospace">Command:</text>
                  <text x="72" y="309" fill="#94a3b8" font-size="9" font-family="monospace">line</text>
                  <rect x="95" y="300" width="1" height="10" fill="#5fa39d" />
                </svg>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Features grid ─────────────────────────────────── -->
    <section class="py-24 border-b border-slate-800">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-14 text-center">
          <h2 class="mb-3 text-3xl font-bold text-slate-50">Everything you need for 2D drafting</h2>
          <p class="text-slate-400 max-w-xl mx-auto">A complete CAD command set, accessible via toolbar, keyboard shortcut, or the command terminal.</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {features.map(f => (
            <div class="rounded-xl border border-slate-800 bg-slate-800/30 p-6 hover:border-slate-700 transition-colors">
              <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={f.icon} />
              </div>
              <h3 class="mb-2 font-semibold text-slate-50">{f.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Privacy section ───────────────────────────────── -->
    <section class="py-24 border-b border-slate-800">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid items-center gap-16 lg:grid-cols-2">
          <div>
            <h2 class="mb-4 text-3xl font-bold text-slate-50">Your drawings never leave your machine</h2>
            <p class="mb-6 text-slate-400 leading-relaxed">
              KulmanLab runs entirely in the browser. There is no server. Your DXF files are parsed locally, stored in your browser's IndexedDB, and exported from your browser — nothing is transmitted anywhere.
            </p>
            <ul class="space-y-3">
              {[
                'No account or login required',
                'No files uploaded to any server',
                'Drawings persist locally via IndexedDB',
                'Works offline once loaded',
              ].map(item => (
                <li class="flex items-start gap-3 text-slate-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 flex-shrink-0 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-xl border border-slate-700 bg-slate-800/40 p-8 text-center">
            <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-brand/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
              </svg>
            </div>
            <p class="text-xl font-semibold text-slate-50 mb-2">Zero data collection</p>
            <p class="text-slate-400 text-sm">No analytics. No telemetry. No cookies. KulmanLab does not know you exist.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Who it's for ──────────────────────────────────── -->
    <section class="py-24 border-b border-slate-800">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-14 text-center">
          <h2 class="mb-3 text-3xl font-bold text-slate-50">Who uses KulmanLab</h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {[
            {
              title: 'Engineers & designers',
              body: 'Quick DXF edits, annotations, and reviews without firing up a full desktop CAD suite.',
            },
            {
              title: 'CNC & laser cutting',
              body: 'Prepare and tweak DXF files for fabrication workflows. Export-ready for any machine.',
            },
            {
              title: 'AutoCAD users',
              body: 'A lightweight alternative for simple tasks. No seat licence needed for quick edits.',
            },
            {
              title: 'Privacy-conscious teams',
              body: 'Confidential drawings that must not leave the machine. No cloud, no upload.',
            },
          ].map(card => (
            <div class="rounded-xl border border-slate-800 bg-slate-800/20 p-6">
              <h3 class="mb-2 font-semibold text-slate-100">{card.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Compatibility row ─────────────────────────────── -->
    <section class="py-16 border-b border-slate-800">
      <div class="mx-auto max-w-6xl px-6 text-center">
        <p class="mb-6 text-sm uppercase tracking-widest text-slate-500">DXF files open correctly in</p>
        <div class="flex flex-wrap items-center justify-center gap-8">
          {['AutoCAD', 'LibreCAD', 'FreeCAD', 'QCAD', 'BricsCAD'].map(name => (
            <span class="text-slate-400 font-medium text-sm">{name}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Bottom CTA ────────────────────────────────────── -->
    <section class="py-32">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="mb-4 text-4xl font-bold text-slate-50">Start drawing for free</h2>
        <p class="mb-8 text-lg text-slate-400">
          No installation. No account. Open the app and draw.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href={APP_URL}
            class="inline-flex items-center gap-2 rounded-lg bg-brand px-8 py-4 text-lg font-medium text-white hover:bg-brand-light transition-colors"
          >
            Launch App
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href={DOCS_URL}
            class="inline-flex items-center gap-2 rounded-lg border border-slate-700 px-8 py-4 text-lg font-medium text-slate-300 hover:border-slate-500 hover:text-slate-50 transition-colors"
          >
            Read the Docs
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- ── Footer ────────────────────────────────────────── -->
  <footer class="border-t border-slate-800 py-10">
    <div class="mx-auto max-w-6xl px-6 flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <a href="/" class="flex items-center gap-2 text-slate-400 hover:text-slate-200 transition-colors">
        <img src="/logo.svg" alt="KulmanLab" class="h-6 w-6 rounded" />
        <span class="text-sm font-medium">KulmanLab</span>
      </a>
      <nav class="flex gap-6 text-sm text-slate-500">
        <a href={APP_URL} class="hover:text-slate-300 transition-colors">App</a>
        <a href={DOCS_URL} class="hover:text-slate-300 transition-colors">Docs</a>
      </nav>
      <p class="text-sm text-slate-600">© {new Date().getFullYear()} KulmanLab</p>
    </div>
  </footer>

</Layout>
