---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const APP_URL = 'https://app.kulmanlab.com';
const DOCS_URL = '/docs';

const features = [
  {
    title: 'Full Drawing Toolkit',
    body: 'Lines, arcs, circles, polylines, splines, ellipses, text, and multileaders. Everything you need for 2D geometry.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />`,
  },
  {
    title: 'Edit & Modify Commands',
    body: 'Move, copy, rotate, mirror, scale, offset, trim, extend, fillet, chamfer. Full modify suite via toolbar or command terminal.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 3M21 7.5H7.5" />`,
  },
  {
    title: 'Dimensions & Annotation',
    body: 'Linear, aligned, radius, diameter, angular, and continue dimensions. All stored as standard DXF DIMENSION objects.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />`,
  },
  {
    title: 'Layer Management',
    body: 'Freeze, lock, isolate, and configure color, linetype, and lineweight per layer. Full control over layer visibility and printability.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3" />`,
  },
  {
    title: 'DXF Import & Export',
    body: 'Read and write industry-standard DXF files (AC1032). Compatible with LibreCAD, FreeCAD, QCAD, BricsCAD, and any DXF-capable software.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l3 3m0 0l3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
  },
  {
    title: 'Grip Editing',
    body: 'Select any entity and drag its grip handles to reshape geometry directly on the canvas. Type a value while dragging for exact displacement.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zm-7.518-.267A8.25 8.25 0 1120.25 10.5M8.288 14.212A5.25 5.25 0 1117.25 10.5" />`,
  },
];

const useCases = [
  {
    title: 'Engineers & designers',
    body: 'Quick DXF edits, annotations, and reviews without firing up a full desktop CAD suite.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />`,
  },
  {
    title: 'CNC & laser cutting',
    body: 'Prepare and tweak DXF files for fabrication workflows. Export-ready for any machine.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
  {
    title: 'Desktop CAD users',
    body: 'A fast browser-based option for simple tasks. No installation or seat licence needed.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />`,
  },
  {
    title: 'Privacy-conscious teams',
    body: 'Confidential drawings that must not leave the machine. No cloud, no upload.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />`,
  },
];

const stats = [
  { value: '50+', label: 'drawing commands' },
  { value: '0 bytes', label: 'ever uploaded' },
  { value: 'Free', label: 'no subscription, no card' },
  { value: 'No account', label: 'just open and draw' },
];
---

<Layout
  title="KulmanLab — Free Online 2D CAD & DXF Editor | No Install"
  description="Free browser-based 2D CAD and DXF editor. AutoCAD-style commands, layers, dimensions, and PDF export — no installation, no account, no data uploaded."
  jsonLd={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "name": "KulmanLab",
        "url": "https://kulmanlab.com"
      },
      {
        "@type": "SoftwareApplication",
        "name": "KulmanLab",
        "url": "https://app.kulmanlab.com",
        "description": "Free browser-based 2D CAD and DXF editor. AutoCAD-style commands, layers, dimensions, and PDF export — no installation, no account required.",
        "applicationCategory": "DesignApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "screenshot": "https://kulmanlab.com/og.png",
        "featureList": "DXF import and export, Command terminal, Layer management, Dimensions and annotations, PDF and PNG export, Grip editing, Works offline, No account required"
      }
    ]
  }}
>

  <!-- ── Navigation ─────────────────────────────────────── -->
  <SiteHeader />

  <main>

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="relative overflow-hidden border-b border-slate-800 pt-0 pb-0">
      <!-- Background decorations -->
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 opacity-[0.045]"
          style="background-image: linear-gradient(#4A8580 1px, transparent 1px), linear-gradient(90deg, #4A8580 1px, transparent 1px); background-size: 40px 40px;">
        </div>
        <div class="absolute inset-x-0 top-0 h-[500px] opacity-25"
          style="background: radial-gradient(ellipse 80% 60% at 50% -5%, #4A8580, transparent);">
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:gap-0">

          <!-- Left: headline & CTAs -->
          <div class="flex-shrink-0 lg:w-[440px] xl:w-[500px] pt-12 lg:py-20 lg:pr-12 xl:pr-16">
            <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand/30 bg-brand/10 px-4 py-1.5 text-sm text-brand">
              <span class="h-2 w-2 rounded-full bg-brand animate-pulse"></span>
              <span data-i18n="hero.badge">Free · No sign-up required</span>
            </div>

            <h1 class="mb-5 text-4xl font-bold leading-tight tracking-tight text-slate-50 lg:text-5xl xl:text-6xl">
              <span data-i18n="hero.h1.line1">Free 2D CAD &amp; DXF Editor</span><br />
              <span class="text-brand" data-i18n="hero.h1.line2">in your browser</span>
            </h1>

            <p class="mb-8 text-lg text-slate-400 leading-relaxed" data-i18n="hero.desc">
              Open DXF files, draw geometry, add dimensions, and export PDF — without installing a single thing.
              A free alternative to desktop CAD that runs in any modern browser.
            </p>

            <div class="flex flex-wrap gap-4">
              <a
                href={APP_URL}
                data-ga-event="launch_app"
                data-ga-source="hero"
                class="inline-flex items-center gap-2 rounded-lg bg-brand px-6 py-3 font-medium text-white shadow-lg shadow-brand/20 hover:bg-brand-light transition-colors"
              >
                <span data-i18n="hero.cta.app">Launch App</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <a
                href={DOCS_URL}
                data-ga-event="docs_click"
                data-ga-source="hero"
                class="inline-flex items-center gap-2 rounded-lg border border-slate-700 px-6 py-3 font-medium text-slate-300 hover:border-slate-500 hover:text-slate-50 transition-colors"
                data-i18n="hero.cta.docs"
              >
                View Docs
              </a>
            </div>
          </div>

          <!-- Right: screenshot carousel — bleeds beyond the right edge on desktop -->
          <div class="relative flex-1 min-w-0 lg:-mr-6 xl:-mr-0 lg:-mb-[100px]">

            <!-- Glow behind the card -->
            <div class="pointer-events-none absolute -inset-8 opacity-35 blur-3xl"
              style="background: radial-gradient(ellipse at 60% 50%, #4A8580, transparent 65%);">
            </div>

            <!-- Left-edge fade: screenshot bleeds into the text column -->
            <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-24 z-10 hidden lg:block"
              style="background: linear-gradient(to right, #0f172a, transparent);">
            </div>

            <!-- Gradient-border card -->
            <div class="rounded-2xl p-px" style="background: linear-gradient(150deg, rgba(74,133,128,0.55) 0%, rgba(74,133,128,0.04) 45%, rgba(74,133,128,0.28) 100%); box-shadow: 0 60px 120px -20px rgba(0,0,0,0.95), 0 20px 40px -10px rgba(0,0,0,0.5);">
              <div class="rounded-2xl overflow-hidden bg-slate-900">

                <!-- Window titlebar -->
                <div class="flex items-center bg-slate-800 px-4 py-2.5 border-b border-slate-700/50">
                  <div class="flex gap-1.5">
                    <div class="h-3 w-3 rounded-full bg-slate-600"></div>
                    <div class="h-3 w-3 rounded-full bg-slate-600"></div>
                    <div class="h-3 w-3 rounded-full bg-slate-600"></div>
                  </div>
                  <div class="flex-1 text-center text-xs text-slate-500">app.kulmanlab.com</div>
                  <div class="w-12 flex-shrink-0"></div>
                </div>

                <!-- Carousel -->
                <div class="relative overflow-hidden">
                  <div id="carousel-track" class="flex transition-transform duration-500 ease-in-out">
                    <img src="/images/app-screenshot.webp" alt="KulmanLab CAD — bolt drawing with dimensions" width="2722" height="1658" class="w-full flex-shrink-0" />
                    <img src="/images/app-screenshot-3.webp" alt="KulmanLab CAD — bolt drawing with layout tabs" width="2756" height="1650" class="w-full flex-shrink-0" loading="lazy" />
                    <img src="/images/app-screenshot-2.webp" alt="KulmanLab CAD — print layout view" width="2726" height="1672" class="w-full flex-shrink-0" loading="lazy" />
                  </div>

                  <!-- Prev / Next buttons -->
                  <button id="carousel-prev" aria-label="Previous screenshot"
                    class="absolute left-3 top-1/2 -translate-y-1/2 flex h-9 w-9 items-center justify-center rounded-full bg-slate-900/70 text-slate-300 hover:bg-slate-900 hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                  </button>
                  <button id="carousel-next" aria-label="Next screenshot"
                    class="absolute right-3 top-1/2 -translate-y-1/2 flex h-9 w-9 items-center justify-center rounded-full bg-slate-900/70 text-slate-300 hover:bg-slate-900 hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </button>

                  <!-- Dots -->
                  <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
                    <button class="carousel-dot h-1.5 w-4 rounded-full bg-brand transition-all" data-index="0" aria-label="Slide 1"></button>
                    <button class="carousel-dot h-1.5 w-1.5 rounded-full bg-slate-600 transition-all" data-index="1" aria-label="Slide 2"></button>
                    <button class="carousel-dot h-1.5 w-1.5 rounded-full bg-slate-600 transition-all" data-index="2" aria-label="Slide 3"></button>
                  </div>
                </div>

              </div>
            </div>

            <!-- Bottom fade -->
            <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-32 rounded-b-2xl"
              style="background: linear-gradient(to bottom, transparent 0%, rgba(15,23,42,0.9) 100%);">
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- ── Stats bar ─────────────────────────────────────── -->
    <section class="relative z-10 border-b border-slate-800 bg-slate-900/50">
      <div class="mx-auto max-w-6xl px-6 pt-10 lg:pt-36 pb-0">
        <div class="flex flex-col divide-y divide-slate-800 sm:flex-row sm:divide-x sm:divide-y-0">
          {stats.map((s, i) => (
            <div class="flex-1 px-6 py-7 text-center">
              <div class="text-2xl font-bold text-brand">{s.value}</div>
              <div class="mt-1 text-sm text-slate-500" data-i18n={`stats.${['commands','uploaded','free','account'][i]}`}>{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Features grid ─────────────────────────────────── -->
    <section class="py-24 border-b border-slate-800">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-14 text-center">
          <h2 class="mb-3 text-3xl font-bold text-slate-50" data-i18n="features.h2">Everything you need for 2D drafting</h2>
          <p class="text-slate-400 max-w-xl mx-auto" data-i18n="features.sub">A complete CAD command set, accessible via toolbar, keyboard shortcut, or the command terminal.</p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {features.map(f => (
            <div class="group rounded-xl border border-slate-800 bg-slate-800/20 p-6 hover:border-brand/30 hover:bg-slate-800/40 transition-all duration-200">
              <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-brand/20 bg-gradient-to-br from-brand/20 to-brand/5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={f.icon} />
              </div>
              <h3 class="mb-2 font-semibold text-slate-50" data-i18n={`feature.${features.indexOf(f)}.title`}>{f.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed" data-i18n={`feature.${features.indexOf(f)}.body`}>{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Workflow ──────────────────────────────────────── -->
    <section class="py-24 border-b border-slate-800">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-16 text-center">
          <h2 class="mb-3 text-3xl font-bold text-slate-50" data-i18n="workflow.h2">From sketch to print-ready sheet</h2>
          <p class="text-slate-400 max-w-lg mx-auto" data-i18n="workflow.sub">A complete drafting workflow in three steps, without leaving the browser.</p>
        </div>

        <div class="relative">
          <!-- Connecting line (desktop) -->
          <div class="pointer-events-none absolute hidden md:block top-10 h-px"
            style="left: calc(16.67% + 40px); right: calc(16.67% + 40px); background: linear-gradient(to right, rgba(74,133,128,0.5), rgba(74,133,128,0.15) 50%, rgba(74,133,128,0.5));">
          </div>

          <div class="grid grid-cols-1 gap-14 md:grid-cols-3 md:gap-6">
            {[
              {
                title: 'Model your drawing',
                desc: 'Draw geometry with snap-to-point precision. Type exact X,Y coordinates, add dimensions, and organise by layer.',
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />`,
              },
              {
                title: 'Configure the sheet',
                desc: 'Pick a paper format, set the drawing scale, and arrange model viewports on the layout canvas.',
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z" />`,
              },
              {
                title: 'Print or export',
                desc: 'Preview the layout at full fidelity and export to PDF, PNG, or DXF — ready for fabrication or client review.',
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" />`,
              },
            ].map((step, i) => (
              <div class="flex flex-col items-center text-center">
                <!-- Numbered icon -->
                <div class="relative mb-7 z-10">
                  <div class="flex h-20 w-20 items-center justify-center rounded-full bg-slate-900 ring-8 ring-slate-900">
                    <div class="flex h-16 w-16 items-center justify-center rounded-full border border-brand/25 bg-brand/10">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={step.icon} />
                    </div>
                  </div>
                  <span class="absolute -top-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-brand text-[11px] font-bold text-white shadow-lg shadow-brand/30">
                    {i + 1}
                  </span>
                </div>
                <h3 class="mb-2 text-lg font-semibold text-slate-50" data-i18n={`workflow.step.${i}.title`}>{step.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed max-w-[240px]" data-i18n={`workflow.step.${i}.desc`}>{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Demo GIF ─────────────────────────────────────── -->
    <section class="py-20 border-b border-slate-800">
      <div class="mx-auto max-w-6xl px-6">
