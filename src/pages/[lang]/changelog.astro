---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import type { Lang } from '../../i18n/translations';
import { translations } from '../../i18n/translations';
import { LANGS_NO_EN, buildAlternates } from '../../i18n/utils';
import { releases as baseReleases, releaseTranslations } from '../../i18n/changelog-content';

export function getStaticPaths() {
  return LANGS_NO_EN.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = translations[lang];

const localized = releaseTranslations[lang] ?? releaseTranslations['en'];
const releases = baseReleases.map((r, i) => ({
  ...r,
  title: localized[i]?.title ?? r.title,
  highlights: localized[i]?.highlights ?? r.highlights,
}));
---

<Layout
  title={t['changelog.title']}
  description={t['changelog.desc']}
  canonical={`https://kulmanlab.com/${lang}/changelog/`}
  lang={lang}
  alternates={buildAlternates('changelog')}
>

  <SiteHeader active="changelog" lang={lang} />

  <main class="mx-auto max-w-3xl px-6 py-16">

    <div class="mb-14">
      <h1 class="mb-3 text-4xl font-bold text-slate-50">{t['changelog.heading']}</h1>
      <p class="text-slate-400 text-lg">{t['changelog.subtitle']}</p>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 top-2 bottom-0 w-px bg-slate-800 hidden md:block"></div>

      <div class="space-y-14">
        {releases.map((r) => (
          <article class="relative md:pl-10">
            <!-- Timeline dot -->
            <div class="absolute left-0 top-[7px] -translate-x-[4.5px] hidden md:block">
              <div class="h-2.5 w-2.5 rounded-full border-2 border-brand bg-slate-900"></div>
            </div>

            <!-- Header -->
            <div class="mb-4">
              <div class="flex flex-wrap items-baseline gap-3 mb-1">
                <h2 class="text-xl font-bold text-slate-50">{r.title}</h2>
              </div>
              <div class="flex flex-wrap items-center gap-3">
                <code class="text-xs font-mono text-brand bg-brand/10 border border-brand/20 rounded px-2 py-0.5">
                  {r.version}
                </code>
                <span class="text-sm text-slate-500">{r.date}</span>
              </div>
            </div>

            <!-- Changes -->
            <ul class="space-y-2">
              {r.highlights.map((item) => {
                const isFeature = !item.toLowerCase().startsWith('fix') && !item.toLowerCase().startsWith('revert');
                return (
                  <li class="flex items-start gap-3 text-sm text-slate-300 leading-relaxed">
                    <span class={`mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full ${isFeature ? 'bg-brand' : 'bg-slate-500'}`}></span>
                    {item}
                  </li>
                );
              })}
            </ul>
          </article>
        ))}
      </div>
    </div>

  </main>

  <SiteFooter lang={lang} />

</Layout>
