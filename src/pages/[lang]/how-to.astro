---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import HowToBody from '../../components/HowToBody.astro';
import type { Lang } from '../../i18n/translations';
import { LANGS_NO_EN, buildAlternates } from '../../i18n/utils';
import { howtoContent } from '../../i18n/howto-content';

export function getStaticPaths() {
  return LANGS_NO_EN.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const c = howtoContent[lang] ?? howtoContent['en'];
---

<Layout
  title={c.title}
  description={c.desc}
  canonical={`https://kulmanlab.com/${lang}/how-to/`}
  lang={lang}
  alternates={buildAlternates('how-to')}
>

  <SiteHeader active="howto" lang={lang} />

  <HowToBody lang={lang} />

  <SiteFooter lang={lang} />

</Layout>
