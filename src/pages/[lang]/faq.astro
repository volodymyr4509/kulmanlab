---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import type { Lang } from '../../i18n/translations';
import { translations } from '../../i18n/translations';
import { LANGS_NO_EN, buildAlternates } from '../../i18n/utils';
import { faqContent } from '../../i18n/faq-content';

export function getStaticPaths() {
  return LANGS_NO_EN.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = translations[lang];

const rawSections = faqContent[lang] ?? faqContent['en'];
const sections = rawSections.map(s => ({
  heading: (t as Record<string, string>)[s.headingKey] ?? s.headingKey,
  items: s.items,
}));

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": sections.flatMap(s => s.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  }))),
};
---

<Layout
  title={t['faq.title']}
  description={t['faq.desc']}
  canonical={`https://kulmanlab.com/${lang}/faq/`}
  lang={lang}
  alternates={buildAlternates('faq')}
  jsonLd={faqJsonLd}
>

  <SiteHeader active="faq" lang={lang} />

  <main class="mx-auto max-w-3xl px-6 py-16">

    <div class="mb-14">
      <h1 class="mb-3 text-4xl font-bold text-slate-50">{t['faq.heading']}</h1>
      <p class="text-slate-400 text-lg">{t['faq.subtitle']}</p>
    </div>

    <div class="space-y-12">
      {sections.map(section => (
        <div>
          <h2 class="mb-5 text-xs font-bold uppercase tracking-widest text-slate-500">{section.heading}</h2>
          <div class="divide-y divide-slate-800 rounded-xl border border-slate-800 overflow-hidden">
            {section.items.map(item => (
              <details class="group">
                <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-sm font-medium text-slate-200 hover:text-slate-50 transition-colors select-none list-none">
                  {item.q}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 flex-shrink-0 text-slate-500 transition-transform duration-200 group-open:rotate-180"
                    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="border-t border-slate-800 bg-slate-800/30 px-5 py-4 text-sm text-slate-400 leading-relaxed">
                  {item.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 rounded-xl border border-slate-800 bg-slate-800/20 px-6 py-8 text-center">
      <p class="mb-1 text-slate-300 font-medium">{t['faq.still_q']}</p>
      <p class="text-sm text-slate-500">
        Ask on <a href="https://www.reddit.com/r/kulmanlab/" target="_blank" rel="noopener" class="text-brand hover:text-brand-light transition-colors">r/kulmanlab</a> or open an issue on <a href="https://github.com/volodymyr4509/kulmanlab" target="_blank" rel="noopener" class="text-brand hover:text-brand-light transition-colors">GitHub</a>.
      </p>
    </div>

  </main>

  <SiteFooter lang={lang} />

</Layout>
