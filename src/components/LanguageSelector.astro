---
import { languages } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
  page?: 'home' | 'faq' | 'changelog';
}
const { lang: currentLang = 'en', page = 'home' } = Astro.props;
---

<div class="relative" id="lang-wrapper" data-current-lang={currentLang} data-page={page}>
  <button
    id="lang-toggle"
    aria-label="Select language"
    aria-expanded="false"
    aria-haspopup="listbox"
    class="flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-sm text-slate-400 hover:text-slate-200 hover:bg-slate-800 transition-colors"
  >
    <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
    </svg>
    <span id="lang-label">{currentLang.toUpperCase()}</span>
    <svg class="h-3 w-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    id="lang-dropdown"
    role="listbox"
    aria-label="Language"
    class="hidden absolute right-0 top-full mt-1 w-44 rounded-xl border border-slate-700 bg-slate-900 shadow-xl shadow-black/40 z-50 overflow-hidden py-1"
  >
    {languages.map(({ code, label, flag }) => (
      <button
        role="option"
        data-lang={code}
        class="lang-option flex w-full items-center gap-2.5 px-3 py-2 text-sm text-slate-300 hover:bg-slate-800 hover:text-slate-50 transition-colors"
      >
        <span class="text-base leading-none">{flag}</span>
        <span>{label}</span>
        <svg data-check class={`ml-auto h-3.5 w-3.5 text-brand ${code === currentLang ? '' : 'hidden'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </button>
    ))}
  </div>
</div>

<script>
  import { translations, type Lang } from '../i18n/translations';

  const LS_KEY = 'kl-lang';
  const wrapper = document.getElementById('lang-wrapper');
  const currentLang = (wrapper?.dataset.currentLang ?? 'en') as Lang;
  const page = wrapper?.dataset.page ?? 'home';

  function langToUrl(lang: Lang): string {
    const path = window.location.pathname;
    // Docs pages: /docs/... → /de/docs/... and vice versa
    if (path.startsWith('/docs/') || path === '/docs') {
      return lang === 'en' ? path : `/${lang}${path}`;
    }
    if (path.startsWith('/de/docs/') || path === '/de/docs') {
      const stripped = path.replace(/^\/de/, '');
      return lang === 'en' ? stripped : path;
    }
    // Standard locale pages
    const suffix = page === 'home' ? '/' : `/${page}`;
    if (lang === 'en') return suffix;
    return `/${lang}${page === 'home' ? '/' : `/${page}`}`;
  }

  function applyLang(lang: Lang) {
    const t = translations[lang];
    if (!t) return;
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n!;
      if (t[key] !== undefined) el.textContent = t[key];
    });
    const label = document.getElementById('lang-label');
    if (label) label.textContent = lang.toUpperCase();
    document.querySelectorAll<HTMLElement>('.lang-option').forEach(btn => {
      const check = btn.querySelector<SVGElement>('[data-check]');
      if (!check) return;
      if (btn.dataset.lang === lang) check.classList.remove('hidden');
      else check.classList.add('hidden');
    });
    // Update locale-aware nav links
    document.querySelectorAll<HTMLAnchorElement>('[data-locale]').forEach(el => {
      const p = el.dataset.locale as string;
      const suffix = p === 'home' ? '/' : `/${p}`;
      el.href = lang === 'en' ? suffix : `/${lang}${suffix}`;
    });
    document.documentElement.lang = lang;
    localStorage.setItem(LS_KEY, lang);
  }

  // Toggle dropdown
  const toggle = document.getElementById('lang-toggle');
  const dropdown = document.getElementById('lang-dropdown');

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = dropdown?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!wrapper?.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Language selection — navigate to locale URL
  document.querySelectorAll<HTMLElement>('.lang-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.lang as Lang;
      if (!lang) return;
      localStorage.setItem(LS_KEY, lang);
      dropdown?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      // Navigate to locale page
      window.location.href = langToUrl(lang);
    });
  });

  // On English pages, apply saved/detected language for text swapping
  if (currentLang === 'en') {
    const saved = localStorage.getItem(LS_KEY) as Lang | null;
    const browser = navigator.language.slice(0, 2) as Lang;
    const detected = (saved && saved in translations) ? saved : (browser in translations ? browser : 'en');
    if (detected !== 'en') {
      applyLang(detected);
    }
  } else {
    // Persist current locale so English pages (like /docs) can auto-apply it
    localStorage.setItem(LS_KEY, currentLang);
  }
</script>
