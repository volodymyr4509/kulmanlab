---
import { languages } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
  page?: 'home' | 'faq' | 'changelog';
  docsSlug?: string;
}
const { lang: currentLang = 'en', page = 'home', docsSlug } = Astro.props;

const byCode = Object.fromEntries(languages.map(l => [l.code, l]));

function hrefFor(code: string): string {
  const prefix = code === 'en' ? '' : `/${code}`;
  if (docsSlug !== undefined) {
    return docsSlug ? `${prefix}/docs/${docsSlug}/` : `${prefix}/docs/` || '/docs/';
  }
  if (page === 'faq') return `${prefix}/faq/` || '/faq/';
  if (page === 'changelog') return `${prefix}/changelog/` || '/changelog/';
  return prefix ? `${prefix}/` : '/';
}

const groups: { label: string; codes: string[] }[] = [
  { label: 'Europe', codes: ['en', 'de', 'es', 'fr', 'it', 'pt', 'pl', 'uk', 'el', 'sv', 'nl'] },
  { label: 'Middle East & Africa', codes: ['ar', 'he', 'tr', 'sw', 'ha'] },
  { label: 'South & East Asia', codes: ['hi', 'ur', 'bn', 'pa', 'zh', 'ja', 'ko', 'vi', 'th', 'id', 'ms', 'tl'] },
];
---

<div class="relative" id="lang-wrapper" data-current-lang={currentLang} data-page={page}>
  <button
    id="lang-toggle"
    aria-label="Select language"
    aria-expanded="false"
    aria-haspopup="listbox"
    class="flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-sm text-slate-400 hover:text-slate-200 hover:bg-slate-800 transition-colors"
  >
    <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
    </svg>
    <span id="lang-label">{currentLang.toUpperCase()}</span>
    <svg class="h-3 w-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    id="lang-dropdown"
    role="listbox"
    aria-label="Language"
    class="hidden absolute right-0 top-full mt-1 w-52 rounded-xl border border-slate-700 bg-slate-900 shadow-xl shadow-black/40 z-50 overflow-y-auto max-h-[80vh] py-1"
  >
    {groups.map((group, gi) => (
      <>
        {gi > 0 && <div class="my-1 border-t border-slate-800" />}
        <div class="px-3 pt-1.5 pb-0.5 text-xs font-medium text-slate-500 uppercase tracking-wider">{group.label}</div>
        {group.codes.map(code => {
          const lang = byCode[code];
          if (!lang) return null;
          return (
            <a
              role="option"
              href={hrefFor(lang.code)}
              data-lang={lang.code}
              class="lang-option flex w-full items-center gap-2.5 px-3 py-1.5 text-sm text-slate-300 hover:bg-slate-800 hover:text-slate-50 transition-colors"
            >
              <span class="text-base leading-none flex-shrink-0">{lang.flag}</span>
              <span class="whitespace-nowrap">{lang.label}</span>
              <svg data-check class={`ml-auto flex-shrink-0 h-3.5 w-3.5 text-brand ${lang.code === currentLang ? '' : 'hidden'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </a>
          );
        })}
      </>
    ))}
  </div>
</div>

<script>
  import { translations, type Lang } from '../i18n/translations';

  const LS_KEY = 'kl-lang';
  const wrapper = document.getElementById('lang-wrapper');
  const currentLang = (wrapper?.dataset.currentLang ?? 'en') as Lang;
  const page = wrapper?.dataset.page ?? 'home';

  function langToUrl(lang: Lang): string {
    const path = window.location.pathname;
    // Strip leading /{locale} prefix (e.g. /de, /es) to get the bare path
    const bare = path.replace(/^\/[a-z]{2}(?=\/|$)/, '') || '/';
    // Docs, privacy, about, and how-to pages stay on the equivalent locale path
    if (bare.startsWith('/docs') || bare.startsWith('/privacy') || bare.startsWith('/about') || bare.startsWith('/how-to')) {
      return lang === 'en' ? bare : `/${lang}${bare}`;
    }
    // Standard locale pages (home, faq, changelog)
    const suffix = page === 'home' ? '/' : `/${page}/`;
    return lang === 'en' ? suffix : `/${lang}${suffix}`;
  }

  function applyLang(lang: Lang) {
    const t = translations[lang];
    if (!t) return;
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n!;
      if (t[key] !== undefined) el.textContent = t[key];
    });
    const label = document.getElementById('lang-label');
    if (label) label.textContent = lang.toUpperCase();
    document.querySelectorAll<HTMLElement>('.lang-option').forEach(btn => {
      const check = btn.querySelector<SVGElement>('[data-check]');
      if (!check) return;
      if (btn.dataset.lang === lang) check.classList.remove('hidden');
      else check.classList.add('hidden');
    });
    // Update locale-aware nav links
    document.querySelectorAll<HTMLAnchorElement>('[data-locale]').forEach(el => {
      const p = el.dataset.locale as string;
      const suffix = p === 'home' ? '/' : `/${p}/`;
      el.href = lang === 'en' ? suffix : `/${lang}${suffix}`;
    });
    document.documentElement.lang = lang;
  }

  // Toggle dropdown
  const toggle = document.getElementById('lang-toggle');
  const dropdown = document.getElementById('lang-dropdown');

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = dropdown?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!wrapper?.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Language selection — navigate to locale URL
  document.querySelectorAll<HTMLElement>('.lang-option').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const lang = btn.dataset.lang as Lang;
      if (!lang) return;
      localStorage.setItem(LS_KEY, lang);
      dropdown?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      // Navigate to locale page
      window.location.href = langToUrl(lang);
    });
  });

  // On English pages: an explicit saved preference redirects to the localized
  // page (e.g. arriving at /privacy/ with uk selected → /uk/privacy/). Browser
  // language alone (no saved choice) only soft-swaps the data-i18n labels.
  if (currentLang === 'en') {
    const saved = localStorage.getItem(LS_KEY) as Lang | null;
    if (saved && saved !== 'en' && saved in translations) {
      const target = langToUrl(saved);
      if (target !== window.location.pathname) {
        window.location.replace(target);
      }
    } else if (!saved) {
      const browser = navigator.language.slice(0, 2) as Lang;
      if (browser !== 'en' && browser in translations) {
        applyLang(browser);
      }
    }
  } else {
    // Persist current locale so English pages (like /docs) can auto-apply it
    localStorage.setItem(LS_KEY, currentLang);
  }
</script>
